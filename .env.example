POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=replace_with_a_strong_database_password
DATABASE_URL=postgresql+asyncpg://your_database_user:replace_with_a_strong_database_password@localhost:5432/your_database_name
ADMIN_USERNAME=replace_with_admin_username
ADMIN_PASSWORD=replace_with_a_strong_admin_password
ADMIN_TOKEN_SECRET=replace_with_a_long_random_token_secret
ADMIN_TOKEN_EXPIRE_MINUTES=120
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:4200,http://127.0.0.1:4200
